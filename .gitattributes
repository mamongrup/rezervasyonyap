# Tüm metin dosyaları LF ile saklanır (Windows'ta checkout sırasında CRLF'e çevrilir)
* text=auto eol=lf

# Kesinlikle LF kalacak dosyalar (script, config, kaynak kod)
*.gleam    text eol=lf
*.erl      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.sql      text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.sh       text eol=lf
*.env      text eol=lf
*.env.*    text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.ps1      text eol=crlf

# İkili dosyalar — hiç dokunma
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.beam     binary
*.ez       binary
