PORT=8080
WISP_SECRET_KEY_BASE=replace-with-long-random-secret-at-least-64-characters

# Tek satır (önerilen): şifresiz yerel postgres
# DATABASE_URL=postgresql://postgres@127.0.0.1:5432/travel

# veya ayrı değişkenler
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=travel
PGUSER=postgres
# PGPASSWORD=

# PayTR (iframe token + Bildirim URL 2. adım)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=1
# Panel: Bildirim URL → https://ALAN/api/v1/integrations/paytr/notification
# merchant_oid = rezervasyon UUID (token isteğindeki ile aynı)

# NetGSM SMS
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_MSGHEADER=

# Yapay zeka iş kuyruğu (DeepSeek — OpenAI uyumlu API)
# Anahtar yoksa işler "failed" olur. Sağlayıcıyı aç: UPDATE ai_providers SET is_active = true WHERE code = 'deepseek';
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Fatura bildirimleri (isteğe bağlı — boş bırakılırsa gönderilmez)
# JSON POST: fatura oluşturma / iptal olayları
# INVOICE_NOTIFY_WEBHOOK_URL=https://example.com/hooks/invoices
# Resend (https://resend.com) — INVOICE_NOTIFY_TO alıcı e-posta
# RESEND_API_KEY=re_...
# INVOICE_NOTIFY_FROM=noreply@yourdomain.com
# INVOICE_NOTIFY_TO=ops@yourdomain.com
