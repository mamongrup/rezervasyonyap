# PostgreSQL
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/travel
# veya PGHOST / PGPORT / PGDATABASE / PGUSER / PGPASSWORD

# CORS — İzin verilen frontend origin'leri (virgülle ayrılmış).
# Boş bırakılırsa geliştirme modunda tüm origin'lere echo yapar.
# Üretimde mutlaka set edin: https://rezervasyonyap.tr,https://www.rezervasyonyap.tr
# CORS_ALLOWED_ORIGINS=https://rezervasyonyap.tr,https://www.rezervasyonyap.tr

# PayTR
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=1

# Paratika (Ortak Ödeme Sayfası — SESSIONTOKEN + sdSha512)
# PARATIKA_MERCHANT=
# PARATIKA_MERCHANT_USER=
# PARATIKA_MERCHANT_PASSWORD=
# PARATIKA_SD_SECRET=
# Panel payment_gateways.paratika.mode (sandbox|production) URL seçer; env bunları ezer.
# PARATIKA_API_BASE=https://entegrasyon.paratika.com.tr/paratika/api/v2
# PARATIKA_HPP_BASE=https://entegrasyon.paratika.com.tr/payment/
# Canlı: https://vpos.paratika.com.tr/paratika/api/v2 ve https://vpos.paratika.com.tr/payment/

# Paratika RETURNURL tam adresi: API_PUBLIC_URL + /api/v1/integrations/paratika/return
API_PUBLIC_URL=http://127.0.0.1:8080

# Yolcu360 Agency API (araç kiralama) — https://apidocs.yolcu360.com/getting-started
# YOLCU360_ENABLED=1
# YOLCU360_BASE_URL=https://staging.api.pro.yolcu360.com/api/v1
# YOLCU360_API_KEY=
# YOLCU360_API_SECRET=

# Ödeme sonrası tarayıcı yönlendirmesi (Next.js kökü)
TRAVEL_PUBLIC_ORIGIN=http://127.0.0.1:3000

# CDN (Bunny / Cloudflare) — pull_zone_url veritabanında güncellenir veya panelden
# Aktif sağlayıcı: POST /api/v1/media/cdn/active { "code": "bunny" | "cloudflare" }

# DeepSeek — canlı destek AI yanıtları (support chat, ai_mode ≠ off)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
