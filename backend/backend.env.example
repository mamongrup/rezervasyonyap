# Yerel travel-api ortamı (Laragon / Windows)
# Kurulum: bu dosyayı backend.env olarak kopyalayın (git'e eklenmez).
#
#   copy backend.env.example backend.env
#
# PowerShell ile API başlatma: ..\scripts\start-travel-api.ps1

# PostgreSQL (Laragon varsayılanı — şifre genelde boş)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=travel
PGUSER=postgres
PGPASSWORD=

PORT=8080
API_PUBLIC_URL=http://127.0.0.1:8080
TRAVEL_PUBLIC_ORIGIN=http://127.0.0.1:3000

# Turna uçuş araması — DB panel kaydı boşsa env kullanılır
TURNA_ENABLED=1
TURNA_BASE_URL=https://api.turna.com
# Canlı anahtarınızı buraya yazın (repoya commit etmeyin):
TURNA_API_KEY=
TURNA_COUNTRY_CODE=TR
TURNA_CURRENCY_CODE=TRY
TURNA_LANGUAGE_CODE=tr

# Travelrobot / KPlus — panel kaydı boşsa env kullanılır (şifreleri repoya commit etmeyin)
TRAVELROBOT_ENABLED=1
TRAVELROBOT_BASE_URL=https://api.bookingagora.com/v0
TRAVELROBOT_CHANNEL_CODE=
TRAVELROBOT_CHANNEL_PASSWORD=
# Statik içerik API (otel kodları, destinasyonlar)
TRAVELROBOT_STATIC_BASE_URL=https://static.travelchain.online/api
TRAVELROBOT_STATIC_USER=
TRAVELROBOT_STATIC_PASSWORD=
TRAVELROBOT_LISTING_STATUS=published
TRAVELROBOT_IMPORT_TOURS=1
TRAVELROBOT_IMPORT_HOTELS=1
TRAVELROBOT_IMPORT_HOTEL_ROOMS=1
TRAVELROBOT_IMPORT_FLIGHTS=0
