# Excalibur MySQL (MariaDB) — geçici import kaynağı
# Dosya: /etc/rezervasyonyap/excalibur-mysql.env
# chmod 600 /etc/rezervasyonyap/excalibur-mysql.env
#
# ÖNEMLİ: Canlı site PostgreSQL "travel" kullanır (backend.env).
# Bu dosya yalnızca indirdiğiniz .sql dump'ının import edildiği MariaDB içindir.
#
# Plesk → Veritabanları listesinden dump'ı hangi DB'ye import ettiyseniz onu yazın.
# Sık görülen: rezervasyonyap (Plesk MariaDB)
# Dump dosya adı rezervasyonyapco_excalibur olsa bile sunucu DB adı farklı olabilir.

MYSQL_HOST=127.0.0.1
MYSQL_USER=PLESK_MARIADB_KULLANICI
MYSQL_PASSWORD=PLESK_MARIADB_SIFRESI
MYSQL_DATABASE=rezervasyonyap
