# Frontend runtime env for travel-web.service (systemd EnvironmentFile)
# Copy to: /etc/rezervasyonyap/frontend.env
#
# --- Kritik: tek repo yolu + tarayıcı API kökü ---
# - deploy/deploy.sh hangi klasörde çalışıyorsa, travel-web.service içindeki
#   WorkingDirectory de O frontend olmalı (örn. .../httpdocs/frontend). Aksi halde
#   yeni build alınır ama systemd eski .next ile next start eder.
# - NEXT_PUBLIC_* npm run build sırasında JS içine gömülür; deploy.sh önce bu dosyayı source eder.
# - NEXT_PUBLIC_API_URL tarayıcıdaki (use client) fetch adresidir. 127.0.0.1 sadece
#   tarayıcı sunucunun localhost'unu gösterir; uzaktan Yönetim/Yapay zeka ÇALIŞMAZ.
#   Üretimde genelde vitrin HTTPS kökü kullanın (nginx aynı hostta /api/v1 proxy ise):
#     NEXT_PUBLIC_API_URL=https://rezervasyonyap.tr
#   Sunucu tarafı (RSC) için loopback ayrı:
#     INTERNAL_API_ORIGIN=http://127.0.0.1:8080
#   INTERNAL_API_ORIGIN yoksa kod sunucuda API_URL’e bakar (aynı Gleam kökü, sonda /api yok).

NEXT_PUBLIC_API_URL=https://rezervasyonyap.tr
INTERNAL_API_ORIGIN=http://127.0.0.1:8080
# İsteğe bağlı yedek (INTERNAL ile aynı olabilir): API_URL=http://127.0.0.1:8080
INTERNAL_MIDDLEWARE_REWRITE_ORIGIN=http://127.0.0.1:3000
NODE_ENV=production
PORT=3000

# --- Google Maps (Places / JS harita / sunucu proxy) -----------------------------
# Tarayıcıdaki MapPicker vb. için (npm run build sırasında bundle'a gömülür):
#   NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...
# Sunucu route'ları (/api/places-nearby, /api/distance-matrix) için runtime + build:
#   GOOGLE_MAPS_API_KEY=...
# Genelde aynı anahtar; yalnızca biri tanımlıysa kod diğerine yedeklenir. Üretimde kalıcı
# konum: bu dosyanın kopyası /etc/rezervasyonyap/frontend.env (git'e girmez).
# NOT: Anahtarı yalnızca httpdocs/frontend/.env.local'a yazdıysanız deploy.sh içindeki
# git clean artık bu dosyaları silmez; yine de systemd EnvironmentFile olarak yukarıdaki
# dosyayı kullanmanız önerilir.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

# Canonical / hreflang / Open Graph (npm run build icin; NEXT_PUBLIC_ build'de gomulur)
NEXT_PUBLIC_SITE_URL=https://rezervasyonyap.tr

# Tatil evi vitrinde liste/detay «gecelik» için listing_price_rules min–max aralığı (varsayılan: açık).
# Kapatmak için: 0 — sonra mutlaka yeniden npm run build + travel-web restart.
# NEXT_PUBLIC_HOLIDAY_HOME_RULE_PRICE_RANGE=0

# Opsiyonel: kuruma bagli navigation menusu kullaniyorsaniz acin
# NEXT_PUBLIC_NAVIGATION_ORGANIZATION_ID=
