+export interface HotelFaqSource {
+  /** "14:00Ă”Ă‡Ă´23:00" gibi serbest metin (locale ile gelir) */
+  checkInLine?: string
+  /** "12:00'a kadar" gibi serbest metin (locale ile gelir) */
