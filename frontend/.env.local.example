# Next.js yalnızca .env.local dosyasını yükler (başındaki nokta şart). "env.local" okunmaz.
# Kurulum: bu dosyayı .env.local olarak kopyalayın.

NEXT_PUBLIC_THEME_DIR=ltr
# Gleam kökü — sonda / veya /api YOK; kod /api/v1/... ekler.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
# Yerel vitrin canlı API/DB kullanırken Pexels vb. /uploads görselleri (boşsa geliştirmede API origin):
# NEXT_PUBLIC_API_URL=https://rezervasyonyap.tr
# NEXT_PUBLIC_UPLOADS_ORIGIN=https://rezervasyonyap.tr

# İsteğe bağlı: `menus` tablosunda kuruma bağlı `hero_search` / header menüsü kullanılıyorsa,
# önyüzün aynı satırı okuması için kurum UUID’si (panelde menü satırında "org …" ile görünür).
# Boş bırakılırsa public API yalnızca site geneli menüyü (`organization_id` NULL) kullanır.
# NEXT_PUBLIC_NAVIGATION_ORGANIZATION_ID=

# VPS üretim (Next sunucu tarafı: RSC, Route Handlers). Tarayıcıya gitmez.
# Örnek: INTERNAL_API_ORIGIN=http://127.0.0.1:8080
# Bu satır yoksa sunucu, hairpin olmadan kendi domain'inize gidemeyebilir.
# NEXT_PUBLIC_API_URL=https://alanadiniz.com
# INTERNAL_API_ORIGIN=http://127.0.0.1:8080
#
# Plesk/Apache: arka uca yanlış Host (localhost:3000) gelince middleware rewrite
# https://localhost:3000 üretip EPROTO verebilir. Üretimde şunu ekleyin (PORT ile aynı):
# INTERNAL_MIDDLEWARE_REWRITE_ORIGIN=http://127.0.0.1:3000

# İlan detayında `ship-and-castle-hotel` için demo ücret / kısa konaklama örnekleri (varsayılan: kapalı)
# NEXT_PUBLIC_ENABLE_DEMO_LISTING_EXTRAS=true

# Tatil evi vitrinde liste/detay «gecelik» için listing_price_rules min–max aralığı (varsayılan: açık).
# Kapatmak için: 0 — sonra `next dev` / `next build` ortamını yeniden yükleyin (sunucuyu durdurup başlatın).
# NEXT_PUBLIC_HOLIDAY_HOME_RULE_PRICE_RANGE=0

# —— Site kökü (canonical, Open Graph, Twitter, metadataBase, JSON-LD) ——
# Yerel: aşağıdaki gibi bırakılabilir. Boşsa geliştirmede http://127.0.0.1:3000; Vercel'de VERCEL_URL kullanılır.
# Üretim: mutlaka gerçek alan adınızı yazın (https, sondaki / olmadan).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Örnek üretim: NEXT_PUBLIC_SITE_URL=https://www.siteniz.com

# Checkout → Gleam API (yayında ilan UUID’si veritabanından)
NEXT_PUBLIC_CHECKOUT_LISTING_ID=
NEXT_PUBLIC_CHECKOUT_CURRENCY=TRY
NEXT_PUBLIC_CHECKOUT_UNIT_PRICE=100.00

# Backend ile aynı kök (Paratika RETURNURL yönlendirmesi — örn. http://127.0.0.1:3000)
NEXT_PUBLIC_TRAVEL_PUBLIC_ORIGIN=http://127.0.0.1:3000

# Aktif sanal POS API'de yoksa: PayTR iFrame (0 = doğrudan pay-done)
NEXT_PUBLIC_PAYTR_CHECKOUT=1
# ipify başarısız olursa PayTR user_ip yedek
NEXT_PUBLIC_PAYTR_FALLBACK_IP=127.0.0.1

# —— Güven / SEO / footer (NEXT_PUBLIC_SITE_URL ile birlikte kullanın) ——
# Panel → Ayarlar → Marka: favicon_url boşsa `public/favicon.svg` meta ve sekmede yedek olarak kullanılır.
NEXT_PUBLIC_ORG_NAME=Travel
# NEXT_PUBLIC_ORG_LEGAL_NAME=Acente Unvanı A.Ş.
# NEXT_PUBLIC_ORG_LOGO_URL=https://example.com/logo.png
# NEXT_PUBLIC_SITE_TAGLINE=Kısa marka sloganı
# NEXT_PUBLIC_TURSAB_NO=12345
# NEXT_PUBLIC_TURSAB_VERIFY_URL=https://www.tursab.org.tr/
NEXT_PUBLIC_SITE_PHONE=+90 212 000 00 00
NEXT_PUBLIC_SITE_EMAIL=info@example.com
# Çok satırlı adres için \n kullanabilirsiniz
# NEXT_PUBLIC_SITE_ADDRESS=İstanbul, Türkiye
# Sadece rakamlar (ülke kodu ile), örn: 905551234567
# NEXT_PUBLIC_WHATSAPP_E164=905551234567
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
# Aynı alanlar (ve iletişim e-postası / telefon / adres / WhatsApp) panelden de yönetilebilir:
# Yönetim → Genel ayarlar → «Vitrin iletişim ve sosyal» — `site_settings.branding` içine yazılır;
# dolu olduklarında yukarıdaki NEXT_PUBLIC_* değerlerinin üzerine geçer.

# —— Güvenlik (proxy.ts — Next 16 edge; middleware.ts kullanmayın) ——
# GLOBAL_API_RATE_LIMIT_PER_MIN=300
# Ortam: development | production (HSTS, CSP enforce modu etkiler)
# NODE_ENV=production
# İzin verilen Host header'ları — virgülle ayrılmış, boşsa localhost/127.0.0.1 varsayılır
# ALLOWED_HOSTS=rezervasyonyap.tr,www.rezervasyonyap.tr

# —— Yapay Zeka — DeepSeek (AI Çeviri & Blog İçerik Üretimi) ——
# API anahtarı — https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...
# Model (varsayılan: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat
# API uç noktası (varsayılan: DeepSeek resmi API)
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# Upstream süreleri — Yönetim → Yapay zeka / Genel ayarlar (site_settings.ai); ortam değişkeni kullanılmaz.

# —— İlan galerisi sahne önerisi (görüntü, Route Handler) ——
# Varsayılan: DeepSeek anahtarı varsa önce DeepSeek (çok modlu istek); yoksa OpenAI.
# LISTING_SCENE_VISION_PROVIDER=auto   # auto | deepseek | openai
# DeepSeek görüntü modeli (boşsa çeviri modelinden türetilir; deepseek-chat → deepseek-v4-flash önerilir)
# DEEPSEEK_IMAGE_SCENE_MODEL=deepseek-v4-flash
# DeepSeek görüntü başarısız + auto modunda OpenAI dene: LISTING_SCENE_VISION_FALLBACK_OPENAI=1 ve OPENAI_API_KEY gerekir.
# LISTING_SCENE_VISION_FALLBACK_OPENAI=0
# LISTING_SCENE_VISION_TIMEOUT_MS=45000
# Yalnız OpenAI kullanmak için: LISTING_SCENE_VISION_PROVIDER=openai ve OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_SCENE_MODEL=gpt-4o-mini

# —— Yeni alan adına taşıma (tek "kaynak": site kökü) ——
# 1) Her ortamda mutlaka güncelle:
#    NEXT_PUBLIC_SITE_URL=https://yeni-alan.com
# 2) CDN her zaman `https://cdn.<kök alan adı>` kalıbındaysa (Bunny CNAME) — ayrıca host yazma:
#    CSP_CDN_AUTO=1
#    (İsteğe bağlı) alt alan cdn dışındaysa: CSP_CDN_SUBDOMAIN=medya
# 3) next/image dış host listesi: IMAGE_REMOTE boş bırakılırsa, CSP_CDN_AUTO ile aynı türetme kullanılır.
#    Açık URL istersen: NEXT_PUBLIC_IMAGE_REMOTE_HOST=https://ozel.b-cdn.net
# 4) CDN'i tamamen kapat: CSP_CDN_AUTO ve NEXT_PUBLIC_CDN_AUTO satırlarını sil; IMAGE_REMOTE gerekirse manuel.
#
# NEXT_PUBLIC_SITE_URL=https://127.0.0.1:3000
# CSP_CDN_AUTO=1

# —— Üretim güvenlik başlıkları (next.config + security-headers.mjs) ——
# CDN (Cloudflare, Bunny, vb.) önünde aynı başlıkları "pass-through" veya edge'de tekrarlamayın; çift HSTS/CSP kırılma yapabilir.
# Yerel geliştirmede varsayılanlar güvenli: CSP kapalı, HSTS yok.
#
# CSP_MODE: off | report-only | enforce — üretimde varsayılan report-only (ihlal raporlar, engellemez)
# CSP_MODE=report-only
# İhlal toplama uç noktası (Reporting API veya uyumlu URL)
# CSP_REPORT_URI=https://example.com/csp-report
# HSTS gönderme (HTTP ile test ederken veya alt alan sorununda)
# SECURITY_HSTS_DISABLE=1
# upgrade-insecure-requests CSP direktifini kapat (karışık içerik hata ayıklama)
# SECURITY_UPGRADE_INSECURE=0
# İsteğe bağlı Cross-Origin-Resource-Policy (varsayılan: gönderilmez)
# SECURITY_CORP=same-site
# SECURITY_CORP=cross-origin
#
# HTTP → HTTPS yönlendirme (yalnızca edge'in X-Forwarded-Proto ilettiği üretimde; yanlış proxy ile açmayın)
# ENFORCE_HTTPS_REDIRECT=1
